# Quran Foundation OAuth2 (request credentials at https://api-docs.quran.foundation)
QF_CLIENT_ID=your-qf-client-id
QF_CLIENT_SECRET=your-qf-client-secret
QF_ENV=prelive
QF_AUTH_BASE=https://prelive-oauth2.quran.foundation
QF_API_BASE=https://apis-prelive.quran.foundation
QF_REDIRECT_URI=http://localhost:3000/api/auth/callback

# Random 32+ byte hex string used to encrypt the session cookie
SESSION_SECRET=replace-with-openssl-rand-hex-32

# Quran MCP (no auth required)
QURAN_MCP_URL=https://mcp.quran.ai/
